{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://video-factory.local/schemas/render-manifest.schema.json",
  "title": "video-factory render-manifest.json",
  "description": "Compiler output consumed by hyperframes and the deck adapter. This file is read-only.",
  "type": "object",
  "additionalProperties": false,
  "required": ["meta", "scenes", "transitions", "bgm", "formatOverrides"],
  "properties": {
    "meta": {
      "$ref": "#/$defs/meta"
    },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/renderScene"
      }
    },
    "transitions": {
      "type": "array",
      "items": {
        "$ref": "https://video-factory.local/schemas/scene-specs.schema.json#/$defs/transition"
      }
    },
    "bgm": {
      "oneOf": [
        {
          "$ref": "#/$defs/bgm"
        },
        {
          "type": "null"
        }
      ]
    },
    "formatOverrides": {
      "$ref": "#/$defs/formatOverrides"
    }
  },
  "$defs": {
    "resolution": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height"],
      "properties": {
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["resolution", "fps", "videoTheme", "designTokens", "subtitleConfig"],
      "properties": {
        "resolution": {
          "$ref": "#/$defs/resolution"
        },
        "fps": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "videoTheme": {
          "type": "string",
          "enum": ["dark", "white"]
        },
        "designTokens": {
          "$ref": "https://video-factory.local/schemas/design-tokens.schema.json",
          "readOnly": true,
          "$comment": "Compiler snapshot only. Edits must be applied to design-tokens.json."
        },
        "subtitleConfig": {
          "$ref": "https://video-factory.local/schemas/design-tokens.schema.json#/$defs/subtitle",
          "readOnly": true,
          "$comment": "Resolved subtitle snapshot used for render."
        }
      }
    },
    "wordTiming": {
      "$ref": "https://video-factory.local/schemas/audio-meta.schema.json#/$defs/wordTiming"
    },
    "subtitle": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "startSec", "endSec", "words"],
      "properties": {
        "text": {
          "type": "string"
        },
        "startSec": {
          "type": "number",
          "minimum": 0
        },
        "endSec": {
          "type": "number",
          "minimum": 0
        },
        "words": {
          "type": "array",
          "$comment": "Word-driven rendering is first verified in P2; this contract preserves the timing data.",
          "items": {
            "$ref": "#/$defs/wordTiming"
          }
        }
      }
    },
    "syncPoint": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "itemIndex": {
          "type": "integer",
          "minimum": 0
        },
        "label": {
          "type": "string"
        },
        "startSec": {
          "type": "number",
          "minimum": 0
        },
        "timeSec": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "vizAnimation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stagger", "itemSyncPoints"],
      "properties": {
        "stagger": {
          "type": "number",
          "minimum": 0
        },
        "itemSyncPoints": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/syncPoint"
          }
        }
      }
    },
    "kenBurns": {
      "$ref": "https://video-factory.local/schemas/scene-specs.schema.json#/$defs/kenBurns"
    },
    "renderScene": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sceneId",
        "path",
        "audioPath",
        "audioDurationSec",
        "durationFrames",
        "subtitles",
        "vizAnimation",
        "imagePath",
        "kenBurns",
        "startFrame"
      ],
      "properties": {
        "sceneId": {
          "$ref": "https://video-factory.local/schemas/scene-specs.schema.json#/$defs/sceneId",
          "$comment": "Deck adapter id."
        },
        "path": {
          "type": "string",
          "minLength": 1,
          "$comment": "Deck adapter path: finalized per-scene clip address, not the image asset path."
        },
        "audioPath": {
          "type": "string",
          "minLength": 1
        },
        "audioDurationSec": {
          "type": "number",
          "minimum": 0
        },
        "durationFrames": {
          "type": "integer",
          "minimum": 0,
          "$comment": "Required baked value. Compiler rule: Math.ceil(audioDurationSec * fps); deck adapters must not recover it from durationMs."
        },
        "subtitles": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/subtitle"
          }
        },
        "vizAnimation": {
          "$ref": "#/$defs/vizAnimation"
        },
        "imagePath": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1
            },
            {
              "type": "null"
            }
          ]
        },
        "kenBurns": {
          "$ref": "#/$defs/kenBurns"
        },
        "startFrame": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "duckingKeyframe": {
      "type": "object",
      "additionalProperties": false,
      "required": ["timeSec", "volume"],
      "properties": {
        "timeSec": {
          "type": "number",
          "minimum": 0
        },
        "volume": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "bgm": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "volume", "duckingKeyframes"],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "volume": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "duckingKeyframes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/duckingKeyframe"
          }
        }
      }
    },
    "formatSceneOverride": {
      "type": "object",
      "additionalProperties": false,
      "minProperties": 1,
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "startFrame": {
          "type": "integer",
          "minimum": 0
        },
        "durationFrames": {
          "type": "integer",
          "minimum": 0
        },
        "overrides": {
          "$ref": "https://video-factory.local/schemas/scene-specs.schema.json#/$defs/canvasOverrideNoFormat"
        }
      }
    },
    "formatManifest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["resolution", "fps", "scenes"],
      "properties": {
        "resolution": {
          "$ref": "#/$defs/resolution"
        },
        "fps": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "scenes": {
          "type": "object",
          "propertyNames": {
            "type": "string",
            "pattern": "^s\\d{2,}$"
          },
          "patternProperties": {
            "^s\\d{2,}$": {
              "$ref": "#/$defs/formatSceneOverride"
            }
          },
          "additionalProperties": false
        }
      }
    },
    "formatOverrides": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "16:9": {
          "$ref": "#/$defs/formatManifest"
        },
        "9:16": {
          "$ref": "#/$defs/formatManifest"
        },
        "1:1": {
          "$ref": "#/$defs/formatManifest"
        }
      }
    }
  }
}
