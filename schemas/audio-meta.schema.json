{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://video-factory.local/schemas/audio-meta.schema.json",
  "title": "video-factory audio_meta.json",
  "description": "Audio source of truth persisted after TTS and word extraction.",
  "type": "object",
  "additionalProperties": false,
  "required": ["scenes"],
  "properties": {
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/audioScene"
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    },
    "wordTiming": {
      "type": "object",
      "additionalProperties": false,
      "required": ["word", "start", "end"],
      "properties": {
        "word": {
          "type": "string",
          "minLength": 1
        },
        "start": {
          "type": "number",
          "minimum": 0
        },
        "end": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "audioScene": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sceneId", "audioPath", "audioDurationSec", "words", "sourceHash", "provider", "voice"],
      "properties": {
        "sceneId": {
          "$ref": "https://video-factory.local/schemas/scene-specs.schema.json#/$defs/sceneId"
        },
        "audioPath": {
          "type": "string",
          "minLength": 1
        },
        "audioDurationSec": {
          "type": "number",
          "minimum": 0
        },
        "words": {
          "type": "array",
          "$comment": "Word monotonicity and end >= start are validator/runtime checks, not expressible here without custom keywords.",
          "items": {
            "$ref": "#/$defs/wordTiming"
          }
        },
        "sourceHash": {
          "$ref": "#/$defs/sha256",
          "$comment": "SHA-256 of narration_tts. If unchanged, TTS and alignment may be reused."
        },
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "voice": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
