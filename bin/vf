#!/usr/bin/env node
import { spawnSync } from "node:child_process";
import { createHash } from "node:crypto";
import {
  existsSync,
  mkdirSync,
  readdirSync,
  readFileSync,
  realpathSync,
  renameSync,
  statSync,
  writeFileSync
} from "node:fs";
import path from "node:path";
import { fileURLToPath } from "node:url";
import {
  formatAjvErrors,
  gateRegistry,
  hashGateEvidence,
  listGates,
  normalizeGateId,
  requiredReportFields,
  resolveSchemaName,
  schemaPathForName,
  validateJsonForSchema
} from "../src/gates/registry.mjs";
import {
  formatSemanticViolations,
  validateSemanticsForWrite
} from "../src/gates/semantic.mjs";
import { DEFAULT_PRESET, compileProject } from "../src/compiler/compiler.mjs";

const repoRoot = path.resolve(path.dirname(fileURLToPath(import.meta.url)), "..");
const repoRealRoot = realpathSync(repoRoot);

function usage(exitCode = 0) {
  const text = `vf

Commands:
  vf gate --list
  vf gate list
  vf gate all [--json] [--replay|--execute]
  vf gate <id> [--json] [--replay|--execute]
  vf verify-report <report.json>
  vf write <file> --schema <auto|scene-specs|audio-meta|design-tokens|versions|render-manifest>
  vf compile <projectDir> [--preset <design-tokens.json>] [--fps <number>] [--json]

Default gate mode is --replay for migrated P0 evidence. Use --execute to rerun the PoC script.
`;
  console.log(text.trim());
  process.exit(exitCode);
}

function sha256Bytes(bytes) {
  return createHash("sha256").update(bytes).digest("hex");
}

function sha256File(filePath) {
  return sha256Bytes(readFileSync(filePath));
}

function gitCommit() {
  const result = spawnSync("git", ["rev-parse", "HEAD"], { cwd: repoRoot, encoding: "utf8" });
  return result.status === 0 ? result.stdout.trim() : null;
}

function normalizeRelPath(value) {
  return value.split(path.sep).join("/");
}

function repoRelative(absolutePath) {
  return normalizeRelPath(path.relative(repoRoot, absolutePath));
}

function isInsideRepo(absolutePath) {
  return absolutePath === repoRoot || absolutePath.startsWith(`${repoRoot}${path.sep}`);
}

function isInsideRealRepo(absolutePath) {
  return absolutePath === repoRealRoot || absolutePath.startsWith(`${repoRealRoot}${path.sep}`);
}

function listFilesRecursive(absPath) {
  const entries = readdirSync(absPath, { withFileTypes: true }).sort((a, b) => a.name.localeCompare(b.name));
  const files = [];
  for (const entry of entries) {
    const next = path.join(absPath, entry.name);
    if (entry.isDirectory()) files.push(...listFilesRecursive(next));
    else if (entry.isFile()) files.push(next);
  }
  return files;
}

function canonicalInput(inputSet) {
  const entries = [];
  const uniqueInputs = [...new Set(inputSet ?? [])].sort((a, b) => a.localeCompare(b));
  for (const rel of uniqueInputs) {
    const abs = path.join(repoRoot, rel);
    if (!existsSync(abs)) {
      entries.push({ path: rel, type: "missing", bytes: 0, sha256: null });
      continue;
    }
    const stats = statSync(abs);
    if (stats.isDirectory()) {
      for (const file of listFilesRecursive(abs)) {
        const fileRel = repoRelative(file);
        const bytes = readFileSync(file);
        entries.push({ path: fileRel, type: "file", bytes: bytes.length, sha256: sha256Bytes(bytes) });
      }
    } else if (stats.isFile()) {
      const bytes = readFileSync(abs);
      entries.push({ path: rel, type: "file", bytes: bytes.length, sha256: sha256Bytes(bytes) });
    }
  }
  entries.sort((a, b) => a.path.localeCompare(b.path));
  return {
    entries,
    hash: hashGateEvidence(entries)
  };
}

function legacyEvidenceHash(legacyReport) {
  const evidence = Array.isArray(legacyReport?.evidence) ? legacyReport.evidence : [];
  const entries = evidence
    .map((item) => ({
      path: String(item.path ?? ""),
      sha256: item.sha256 ?? null,
      bytes: item.bytes ?? null
    }))
    .sort((a, b) => a.path.localeCompare(b.path));
  return hashGateEvidence(entries);
}

function readJson(relPath) {
  return JSON.parse(readFileSync(path.join(repoRoot, relPath), "utf8"));
}

function writeReport(id, report) {
  const reportsDir = path.join(repoRoot, "reports");
  mkdirSync(reportsDir, { recursive: true });
  const tmp = path.join(reportsDir, `${id}-report.json.${process.pid}.tmp`);
  const finalPath = path.join(reportsDir, `${id}-report.json`);
  writeFileSync(tmp, `${JSON.stringify(report, null, 2)}\n`);
  renameSync(tmp, finalPath);
  return finalPath;
}

function requiredFieldComplete(report) {
  return requiredReportFields.every((field) => Object.prototype.hasOwnProperty.call(report, field));
}

function reportForGate({ gate, checks, inputSet, evidenceHash, exitCode, startedAt, command }) {
  const input = canonicalInput(inputSet);
  const scriptPath = path.join(repoRoot, gate.script);
  const pass = checks.every((check) => check.pass === true) && exitCode === 0;
  return {
    gate: gate.gate,
    pass,
    checks,
    inputSet,
    canonicalInputMerkleHash: input.hash,
    evidenceHash,
    gateScriptHash: existsSync(scriptPath) ? sha256File(scriptPath) : null,
    gitCommit: gitCommit(),
    command,
    exitCode: pass ? 0 : exitCode || 1,
    startedAt,
    finishedAt: new Date().toISOString()
  };
}

function legacyFailureReport(gate, error) {
  return {
    gate: gate.gate,
    pass: false,
    checks: [
      {
        id: "legacy-report-readable",
        pass: false,
        measured: {
          error: error instanceof Error ? error.message : String(error),
          path: gate.legacyReport
        }
      }
    ],
    exitCode: 1
  };
}

function runLegacyGate(id, gate, mode, command) {
  const startedAt = new Date().toISOString();
  let child = null;
  if (mode === "execute") {
    const hyperframesBin = path.join(repoRoot, "node_modules", ".bin", "hyperframes");
    child = spawnSync("node", [path.join(repoRoot, gate.script)], {
      cwd: path.join(repoRoot, "poc"),
      encoding: "utf8",
      maxBuffer: 128 * 1024 * 1024,
      env: {
        ...process.env,
        HYPERFRAMES_BIN: hyperframesBin
      }
    });
  }

  let legacyReport;
  try {
    legacyReport = readJson(gate.legacyReport);
  } catch (error) {
    legacyReport = legacyFailureReport(gate, error);
  }

  const childExitCode = child ? child.status ?? (child.signal ? 128 : 1) : null;
  const legacyExitCode = Number.isInteger(legacyReport.exitCode) ? legacyReport.exitCode : legacyReport.pass ? 0 : 1;
  const exitCode = mode === "execute" ? childExitCode : legacyExitCode;
  const checks = Array.isArray(legacyReport.checks) ? legacyReport.checks : [];
  const report = reportForGate({
    gate,
    checks,
    inputSet: gate.inputSet,
    evidenceHash: legacyEvidenceHash(legacyReport),
    exitCode,
    startedAt,
    command
  });

  report.pass = exitCode === 0 && legacyReport.pass === true && checks.every((check) => check.pass === true);
  report.exitCode = report.pass ? 0 : exitCode || 1;
  report.mode = mode;
  report.sourceReport = gate.legacyReport;
  if (child) {
    report.execution = {
      exitCode: childExitCode,
      signal: child.signal ?? null,
      error: child.error?.message ?? null
    };
  }

  const reportPath = writeReport(id, report);
  return { id, report, reportPath };
}

function runNativeGate(id, gate, command) {
  const startedAt = new Date().toISOString();
  let result;
  try {
    result = gate.run({ repoRoot });
  } catch (error) {
    result = {
      checks: [
        {
          id: "native-gate-runner",
          pass: false,
          measured: { error: error instanceof Error ? error.message : String(error) }
        }
      ],
      inputSet: [gate.script],
      evidence: []
    };
  }

  const checks = Array.isArray(result.checks) ? result.checks : [];
  const pass = checks.length > 0 && checks.every((check) => check.pass === true);
  const report = reportForGate({
    gate,
    checks,
    inputSet: result.inputSet ?? [gate.script],
    evidenceHash: hashGateEvidence(result.evidence ?? checks),
    exitCode: pass ? 0 : 1,
    startedAt,
    command
  });

  const reportPath = writeReport(id, report);
  return { id, report, reportPath };
}

function runGate(id, options) {
  const normalizedId = normalizeGateId(id);
  const gate = gateRegistry[normalizedId];
  if (!gate) throw new Error(`unknown gate: ${id}`);

  const command = options.command;
  if (gate.kind === "legacy") return runLegacyGate(normalizedId, gate, options.mode, command);
  return runNativeGate(normalizedId, gate, command);
}

function gateForReport(report) {
  const normalized = normalizeGateId(report?.gate);
  if (gateRegistry[normalized]) return { id: normalized, gate: gateRegistry[normalized] };
  const found = Object.entries(gateRegistry).find(([, gate]) => normalizeGateId(gate.gate) === normalized);
  return found ? { id: found[0], gate: found[1] } : null;
}

function inputFilesFromInputSet(inputSet) {
  const files = [];
  const uniqueInputs = [...new Set(inputSet ?? [])].sort((a, b) => a.localeCompare(b));
  for (const rel of uniqueInputs) {
    const abs = path.join(repoRoot, rel);
    if (!existsSync(abs)) continue;
    const stats = statSync(abs);
    if (stats.isDirectory()) files.push(...listFilesRecursive(abs));
    else if (stats.isFile()) files.push(abs);
  }
  return files;
}

function legacyEvidenceBaseDir(gate) {
  const firstSegment = gate.script.split(/[\\/]/)[0];
  return firstSegment ? path.join(repoRoot, firstSegment) : repoRoot;
}

function resolveLegacyEvidencePath(gate, rel, expectedHash = null) {
  const bases = [legacyEvidenceBaseDir(gate), repoRoot];
  const existing = [];
  for (const base of bases) {
    const abs = path.resolve(base, rel);
    if (!isInsideRepo(abs) || !existsSync(abs)) continue;
    existing.push(abs);
    if (expectedHash && sha256File(abs) === expectedHash) return abs;
  }
  return existing[0] ?? path.resolve(legacyEvidenceBaseDir(gate), rel);
}

function verifyLegacyEvidenceFiles(report, gate, failures) {
  const sourceReport = report.sourceReport ?? gate.legacyReport;
  if (!sourceReport) {
    failures.push("legacy report is missing sourceReport");
    return { evidenceHash: null, freshnessFiles: [] };
  }

  let legacyReport;
  try {
    legacyReport = readJson(sourceReport);
  } catch (error) {
    failures.push(`sourceReport is not readable JSON: ${sourceReport}: ${error.message}`);
    return { evidenceHash: null, freshnessFiles: [] };
  }

  const freshnessFiles = [path.join(repoRoot, sourceReport)];
  const evidence = Array.isArray(legacyReport.evidence) ? legacyReport.evidence : [];
  for (const item of evidence) {
    const rel = String(item.path ?? "");
    const abs = resolveLegacyEvidencePath(gate, rel, item.sha256 ?? null);
    if (!isInsideRepo(abs)) {
      failures.push(`legacy evidence escapes repo: ${rel}`);
      continue;
    }
    if (!existsSync(abs)) {
      failures.push(`legacy evidence missing: ${rel}`);
      continue;
    }
    const bytes = readFileSync(abs);
    const actualHash = sha256Bytes(bytes);
    if (item.sha256 && item.sha256 !== actualHash) {
      failures.push(`legacy evidence hash mismatch: ${rel}`);
    }
    if (Number.isInteger(item.bytes) && item.bytes !== bytes.length) {
      failures.push(`legacy evidence byte count mismatch: ${rel}`);
    }
    freshnessFiles.push(abs);
  }

  return {
    evidenceHash: legacyEvidenceHash(legacyReport),
    freshnessFiles
  };
}

function verifyNativeEvidence(gate, failures) {
  let result;
  try {
    result = gate.run({ repoRoot });
  } catch (error) {
    failures.push(`current native gate execution failed: ${error instanceof Error ? error.message : String(error)}`);
    return { evidenceHash: null, freshnessFiles: [] };
  }

  const checks = Array.isArray(result.checks) ? result.checks : [];
  if (checks.length === 0 || checks.some((check) => check.pass !== true)) {
    failures.push("current native gate checks do not all pass");
  }

  return {
    evidenceHash: hashGateEvidence(result.evidence ?? checks),
    freshnessFiles: inputFilesFromInputSet(result.inputSet ?? [])
  };
}

function verifyFreshness(reportPath, freshnessFiles, failures) {
  const reportMtime = statSync(reportPath).mtimeMs;
  const stale = freshnessFiles
    .filter((file) => existsSync(file) && statSync(file).mtimeMs > reportMtime)
    .map((file) => repoRelative(file))
    .sort((a, b) => a.localeCompare(b));
  if (stale.length > 0) {
    failures.push(`report is older than evidence: ${stale.slice(0, 5).join(", ")}${stale.length > 5 ? " ..." : ""}`);
  }
}

function verifyReportCommand(args) {
  const file = targetFileArg(args);
  if (!file) throw new Error("vf verify-report requires a report JSON file");

  const abs = path.resolve(repoRoot, file);
  if (!isInsideRepo(abs)) throw new Error("vf verify-report target must stay inside the repository");
  const report = JSON.parse(readFileSync(abs, "utf8"));
  const failures = [];

  for (const field of requiredReportFields) {
    if (!Object.prototype.hasOwnProperty.call(report, field)) failures.push(`missing required field: ${field}`);
  }
  if (report.pass !== true) failures.push("report pass must be true");
  if (report.exitCode !== 0) failures.push("report exitCode must be 0");

  const gateEntry = gateForReport(report);
  if (!gateEntry) {
    failures.push(`unknown gate in report: ${report.gate}`);
  } else {
    const { gate } = gateEntry;
    const input = canonicalInput(report.inputSet);
    if (report.canonicalInputMerkleHash !== input.hash) {
      failures.push("canonicalInputMerkleHash mismatch");
    }

    const scriptPath = path.join(repoRoot, gate.script);
    const scriptHash = existsSync(scriptPath) ? sha256File(scriptPath) : null;
    if (report.gateScriptHash !== scriptHash) {
      failures.push("gateScriptHash mismatch");
    }

    const currentCommit = gitCommit();
    if (report.gitCommit !== currentCommit) {
      failures.push("gitCommit mismatch");
    }

    const evidence =
      gate.kind === "legacy"
        ? verifyLegacyEvidenceFiles(report, gate, failures)
        : verifyNativeEvidence(gate, failures);
    if (report.evidenceHash !== evidence.evidenceHash) {
      failures.push("evidenceHash mismatch");
    }
    verifyFreshness(abs, evidence.freshnessFiles, failures);
  }

  if (failures.length > 0) {
    console.error(`verify-report: FAIL ${repoRelative(abs)}`);
    for (const failure of failures) console.error(`- ${failure}`);
    process.exitCode = 1;
    return;
  }

  console.log(
    JSON.stringify(
      {
        report: repoRelative(abs),
        verification: "passed"
      },
      null,
      2
    )
  );
}

function listCommand() {
  console.log(JSON.stringify(listGates(), null, 2));
}

function gateCommand(args) {
  const json = args.includes("--json");
  const mode = args.includes("--execute") ? "execute" : "replay";
  const listRequested = args.includes("--list") || args[0] === "list";
  if (listRequested) {
    listCommand();
    return;
  }

  const positional = args.filter((arg) => !arg.startsWith("--"));
  const target = positional[0];
  if (!target || target === "help") usage(0);

  const ids = target === "all" ? Object.keys(gateRegistry) : [target];
  const command = ["node", "bin/vf", ...process.argv.slice(2)].join(" ");
  const results = ids.map((id) => runGate(id, { mode, command }));

  if (json) {
    const payload = results.length === 1 ? results[0].report : results.map((result) => result.report);
    console.log(JSON.stringify(payload, null, 2));
  } else {
    for (const result of results) {
      const status = result.report.pass ? "PASS" : "FAIL";
      console.log(`${result.id}: ${status} ${repoRelative(result.reportPath)}`);
    }
  }

  if (results.some((result) => !result.report.pass || !requiredFieldComplete(result.report))) {
    process.exitCode = 1;
  }
}

function readStdin() {
  return readFileSync(0, "utf8");
}

function optionValue(args, optionName) {
  const index = args.indexOf(optionName);
  if (index < 0) return null;
  const value = args[index + 1];
  if (!value || value.startsWith("--")) throw new Error(`${optionName} requires a value`);
  return value;
}

function targetFileArg(args) {
  return args.find((arg, index) => index === 0 && !arg.startsWith("--")) ?? null;
}

function atomicWriteJson(absPath, data) {
  const parent = path.dirname(absPath);
  mkdirSync(parent, { recursive: true });
  const realParent = realpathSync(parent);
  if (!isInsideRealRepo(realParent)) {
    throw new Error("vf write target parent must stay inside the repository");
  }
  const tmp = `${absPath}.${process.pid}.${Date.now()}.tmp`;
  writeFileSync(tmp, `${JSON.stringify(data, null, 2)}\n`);
  renameSync(tmp, absPath);
}

function writeCommand(args) {
  const file = targetFileArg(args);
  if (!file) throw new Error("vf write requires a target file");
  if (path.extname(file).toLowerCase() !== ".json") {
    throw new Error("vf write accepts JSON targets only");
  }

  const abs = path.resolve(repoRoot, file);
  if (!isInsideRepo(abs)) {
    throw new Error("vf write target must stay inside the repository");
  }

  const schemaArg = optionValue(args, "--schema") ?? "auto";
  const schemaName = resolveSchemaName(schemaArg, file);
  const raw = readStdin();
  let data;
  try {
    data = JSON.parse(raw);
  } catch (error) {
    throw new Error(`JSON parse failed: ${error.message}`);
  }

  const validation = validateJsonForSchema(repoRoot, data, schemaName);
  if (!validation.pass) {
    const violations = formatAjvErrors(validation.errors).map((message) => `- ${message}`).join("\n");
    throw new Error(`schema validation failed: ${schemaName} (${validation.schemaPath})\n${violations}`);
  }

  const semantic = validateSemanticsForWrite({ repoRoot, schemaName, data, targetPath: abs });
  if (!semantic.pass) {
    const violations = formatSemanticViolations(semantic.violations).map((message) => `- ${message}`).join("\n");
    throw new Error(`semantic validation failed: ${schemaName}\n${violations}`);
  }

  atomicWriteJson(abs, data);
  console.log(
    JSON.stringify(
      {
        file: repoRelative(abs),
        schema: schemaName,
        schemaPath: schemaPathForName(schemaName),
        validation: "passed",
        atomic: true
      },
      null,
      2
    )
  );
}

function compileCommand(args) {
  const json = args.includes("--json");
  const projectDir = args.find((arg, index) => index === 0 && !arg.startsWith("--"));
  if (!projectDir) throw new Error("vf compile requires <projectDir>");

  const preset = optionValue(args, "--preset") ?? DEFAULT_PRESET;
  const fpsArg = optionValue(args, "--fps");
  const fps = fpsArg === null ? undefined : Number(fpsArg);
  if (fps !== undefined && (!Number.isFinite(fps) || fps <= 0)) {
    throw new Error("--fps must be a positive number");
  }

  const result = compileProject({
    repoRoot,
    projectDir,
    presetPath: preset,
    fps
  });

  if (json) {
    console.log(JSON.stringify(result, null, 2));
    return;
  }

  console.log(`compile: PASS ${result.buildDir}`);
  console.log(`frames: ${result.timing.totalFrames} @ ${result.timing.fps}fps`);
  console.log(`scenes: ${result.scenes.length}`);
  console.log(`render-lint: hyperframes=${result.renderLint.hyperframesExitCode} custom=${result.renderLint.customViolations}`);
  if (result.warnings.length > 0) {
    console.log(`warnings: ${result.warnings.length}`);
    for (const warning of result.warnings) {
      console.log(`- ${warning.sceneId ? `${warning.sceneId}: ` : ""}${warning.message}`);
    }
  }
}

try {
  const [command, ...args] = process.argv.slice(2);
  if (!command) usage(0);
  if (command === "gate") gateCommand(args);
  else if (command === "verify-report") verifyReportCommand(args);
  else if (command === "write") writeCommand(args);
  else if (command === "compile") compileCommand(args);
  else usage(1);
} catch (error) {
  console.error(error instanceof Error ? error.message : String(error));
  process.exitCode = 1;
}
