{
  "name": "reelforge",
  "version": "0.1.0",
  "private": true,
  "description": "Deterministic narration ReelForge built around hyperframes 0.7.26.",
  "type": "module",
  "license": "Apache-2.0",
  "bin": {
    "vf": "./bin/vf"
  },
  "scripts": {
    "gate": "node bin/vf gate all --replay",
    "gate:list": "node bin/vf gate --list",
    "lint": "node scripts/schema-lint.mjs && node scripts/readme-sync.mjs",
    "precommit": "node scripts/precommit.mjs",
    "schemas": "node scripts/validate-schemas.mjs",
    "selftest": "node tests/vf-selftest.mjs",
    "render": "hyperframes render poc/fixtures/p0a --output out/p0a.mp4 --fps=30 --quality=high --workers=1 --no-browser-gpu"
  },
  "dependencies": {
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "hyperframes": "0.7.26"
  },
  "engines": {
    "node": ">=20"
  }
}
